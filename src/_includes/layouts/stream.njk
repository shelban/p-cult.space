---
layout: layouts/base.njk
---

<section class="stream-detail">
    {% if thumbnail %}
    <div class="stream-thumbnail">
        <img src="{{ thumbnail }}" alt="{{ title }}" />
    </div>
    {% endif %}

    <h2 class="stream-detail-title">
        <span class="stream-title-glitch">{{ title }}</span>
    </h2>

    <div class="stream-detail-meta">
        <span class="meta-item">{{ date | dateDisplay }}</span>
        {% if duration %}<span class="meta-item">{{ duration }}</span>{% endif %}
        {% if vod_url %}
        <a href="{{ vod_url }}" target="_blank" class="vod-badge">
            <span>Дивитись VOD ▶</span>
        </a>
        {% endif %}
    </div>

    {% set displayTags = tags | streamTags %}
    {% if displayTags.length > 0 %}
    <div class="stream-detail-tags">
        {% for tag in displayTags %}<span class="stream-tag-detail">{{ tag }}</span>{% endfor %}
    </div>
    {% endif %}

    <div class="stream-content">
        {{ content | safe }}
    </div>

    {% set timestampGroups = timestamps | streamTimestampGroups(vod_url, 10) %}
    {% if timestampGroups.total > 0 %}
    <div class="stream-timestamps">
        <h3>таймкоди ({{ timestampGroups.total }})</h3>

        <ul class="timestamps-list">
            {% for ts in timestampGroups.visible %}
            <li class="timestamp-item">
                {% if ts.url %}
                <a href="{{ ts.url }}" target="_blank" class="timestamp-link">
                    <span class="timestamp-time">{{ ts.time }}</span>
                    <span class="timestamp-desc">{{ ts.description }}</span>
                </a>
                {% else %}
                <div class="timestamp-link">
                    <span class="timestamp-time">{{ ts.time }}</span>
                    <span class="timestamp-desc">{{ ts.description }}</span>
                </div>
                {% endif %}
            </li>
            {% endfor %}
        </ul>

        {% if timestampGroups.hiddenCount > 0 %}
        <details class="timestamps-more">
            <summary>Показати ще {{ timestampGroups.hiddenCount }} таймкодів</summary>
            <ul class="timestamps-list">
                {% for ts in timestampGroups.hidden %}
                <li class="timestamp-item">
                    {% if ts.url %}
                    <a href="{{ ts.url }}" target="_blank" class="timestamp-link">
                        <span class="timestamp-time">{{ ts.time }}</span>
                        <span class="timestamp-desc">{{ ts.description }}</span>
                    </a>
                    {% else %}
                    <div class="timestamp-link">
                        <span class="timestamp-time">{{ ts.time }}</span>
                        <span class="timestamp-desc">{{ ts.description }}</span>
                    </div>
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
        </details>
        {% endif %}
    </div>
    {% endif %}
</section>

<p class="back-link"><a href="/streams/">← всі стріми</a></p>
